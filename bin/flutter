#!/usr/bin/env bash
# 项目级 Flutter 包装脚本
# - 指向项目根 `flutter/` 目录的 SDK（需自行获取，见 docs/DEPLOY.md）
# - 自动走国内镜像（pub.dev 与 Flutter engine storage）
set -e
ARCHIVE_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
export PUB_HOSTED_URL="${PUB_HOSTED_URL:-https://pub.flutter-io.cn}"
export FLUTTER_STORAGE_BASE_URL="${FLUTTER_STORAGE_BASE_URL:-https://storage.flutter-io.cn}"
exec "$ARCHIVE_ROOT/flutter/bin/flutter" "$@"
